From: Privasys <engineering@privasys.org>
Subject: [PATCH 1/3] nvidia: Enable TDX Confidential Computing detection

The upstream 590.48.01 open kernel modules detect AMD SEV-SNP for
Confidential Computing via cc_platform_has(CC_ATTR_GUEST_MEM_ENCRYPT),
but that helper returns NV_FALSE inside an Intel TDX guest because
TDX advertises memory encryption through a different kernel subsystem.

The driver already has a TDX code path that sets os_cc_tdx_enabled,
but critically does NOT set os_cc_enabled.  Without os_cc_enabled,
the driver never calls set_memory_decrypted() on DMA pages, so the
GPU cannot read them (TDX marks all memory private by default).

Fix: when cpu_feature_enabled(X86_FEATURE_TDX_GUEST) is true, also
set os_cc_enabled = NV_TRUE.  This makes the driver convert DMA pages
from TDX-private to TDX-shared, transferring encryption from the CPU
(TDX) to the GPU hardware (AES-GCM on PCIe).

Also adds debug printks for CC detection state (these can be removed
once the driver is stable).

Requires module parameter: NVreg_RegistryDwords="RmConfidentialCompute=1"

---
 kernel-open/nvidia/nv.c | 5 +++++
 1 file changed, 5 insertions(+)

--- a/kernel-open/nvidia/nv.c
+++ b/kernel-open/nvidia/nv.c
@@ -348,6 +348,7 @@ void nv_detect_conf_compute_platform(
 {
 #if defined(NV_CC_PLATFORM_PRESENT)
     os_cc_enabled = cc_platform_has(CC_ATTR_GUEST_MEM_ENCRYPT);
+    nv_printf(NV_DBG_WARNINGS, "NVRM: CC detect: cc_platform_has=%d\n", os_cc_enabled);
 
 #if defined(NV_CC_ATTR_SEV_SNP)
     os_cc_sev_snp_enabled = cc_platform_has(CC_ATTR_GUEST_SEV_SNP);
@@ -366,6 +367,7 @@ void nv_detect_conf_compute_platform(
     if (cpu_feature_enabled(X86_FEATURE_TDX_GUEST))
     {
         os_cc_tdx_enabled = NV_TRUE;
+        os_cc_enabled = NV_TRUE;
     }
 #endif
 #else
@@ -375,6 +377,8 @@ void nv_detect_conf_compute_platform(
     os_cc_snp_vtom_enabled = NV_FALSE;
     os_cc_tdx_enabled = NV_FALSE;
 #endif //NV_CC_PLATFORM_PRESENT
+    nv_printf(NV_DBG_WARNINGS, "NVRM: CC state: os_cc_enabled=%d os_cc_tdx=%d os_cc_sme=%d\n",
+              os_cc_enabled, os_cc_tdx_enabled, os_cc_sme_enabled);
 }
 
 static
@@ -3843,6 +3847,7 @@ NV_STATUS NV_API_CALL nv_alloc_pages(
 #endif
     if (unencrypted)
         at->flags.unencrypted = NV_TRUE;
+    nv_printf(NV_DBG_WARNINGS, "NVRM: nv_alloc_pages: pages=%d contig=%d unenc=%d\n", page_count, contiguous, unencrypted);
 
     if (node_id != NUMA_NO_NODE)
     {
